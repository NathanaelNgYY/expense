# Shared budgets (Supabase). Client-safe values; security is enforced by RLS.
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY
VITE_EXPECTED_SUPABASE_PROJECT_REF=YOUR-PROJECT

# Optional Apple-hosted installer for the ready-made Apple Pay capture Shortcut.
# Create/share the template from an iPhone, then paste its public iCloud link here.
VITE_APPLE_PAY_SHORTCUT_URL=https://www.icloud.com/shortcuts/YOUR-SHORTCUT-ID

# Sentry browser error monitoring. The DSN is designed to be public.
VITE_SENTRY_DSN=https://PUBLIC-KEY@o0.ingest.sentry.io/PROJECT-ID

# Optional production source-map upload. Keep SENTRY_AUTH_TOKEN secret and set
# these in the deployment provider, not in a committed .env file.
SENTRY_ORG=YOUR-SENTRY-ORG
SENTRY_PROJECT=budget-tracker
SENTRY_AUTH_TOKEN=YOUR-SECRET-SENTRY-AUTH-TOKEN
