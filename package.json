{
  "name": "budget-tracker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck:functions": "deno check supabase/functions/ingest/index.ts supabase/functions/ingest/handler.ts supabase/functions/_shared/rateLimit.ts",
    "size": "node scripts/check-bundle-size.mjs",
    "test:ingest": "vitest run ingestHandler",
    "test:ingest:live": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/test-ingest.ps1"
  },
  "dependencies": {
    "@netlify/blobs": "^10.7.9",
    "@sentry/react": "^10.65.0",
    "@supabase/supabase-js": "^2.110.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  },
  "devDependencies": {
    "@emnapi/core": "1.11.2",
    "@emnapi/runtime": "1.11.2",
    "@eslint/js": "^10.0.1",
    "@netlify/functions": "^5.3.0",
    "@sentry/vite-plugin": "^5.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "4.1.5",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.1.1",
    "supabase": "^2.109.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
